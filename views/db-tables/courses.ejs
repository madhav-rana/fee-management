<% layout('layouts/boilerplate.ejs') %>

<div class="container mt-5">
  <h1 class="mb-4 text-center">Courses</h1>
  <a href="/admin">Back</a>
  <div class="card shadow">
    <div class="card-body">
      <table class="table table-bordered table-striped align-middle">
        <thead class="table-dark">
          <tr>
            <th>#</th>
            <th>Course Name</th>
            <th>Department</th>
            <th>Duration (Years)</th>
            <th>Fee Structure</th>
          </tr>
        </thead>
        <tbody>
          <% if (courses.length > 0) { %>
            <% courses.forEach((c, index) => { %>
              <tr>
                <td><%= index + 1 %></td>
                <td><%= c.courseName %></td>
                <td><%= c.department %></td>
                <td><%= c.durationYears %></td>
                <td>
                  <% if(c.fees) { %>
                    Academic Year: <%= c.fees.academicYear %> <br>
                    Total: ₹<%= c.fees.totalAmount %>
                  <% } else { %>
                    N/A
                  <% } %>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="5" class="text-center text-muted">No courses found.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
