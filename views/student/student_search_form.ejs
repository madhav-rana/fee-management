<% layout('layouts/boilerplate.ejs') %>

<div class="container my-5" style="max-width: 900px;">

  <!-- Header -->
  <div class="text-center mb-4">
    <h2 class="fw-bold">🎓 Student Search</h2>
    <p class="text-muted">Find students by roll number or name</p>
  </div>

  <!-- Card -->
  <div class="card border-0 shadow-lg rounded-4">
    <div class="card-body p-4">

      <form action="/api/v1/students/search" method="GET">

        <div class="row g-3">

          <!-- Search Input -->
          <div class="col-md-6">
            <label class="form-label fw-semibold">Roll No or Name</label>
            <input
              type="text"
              name="query"
              class="form-control form-control-lg rounded-3"
              placeholder="e.g. 101 or Rahul Sharma"
              required
            />
          </div>

          <!-- Year Filter -->
          <div class="col-md-4">
            <label class="form-label fw-semibold">Year</label>
            <select name="year" class="form-select form-select-lg rounded-3">
              <option value="">All Years</option>
              <option value="1">1st Year</option>
              <option value="2">2nd Year</option>
              <option value="3">3rd Year</option>
              <option value="4">4th Year</option>
            </select>
          </div>

          <!-- Search Button -->
          <div class="col-md-2 d-flex align-items-end">
            <button class="btn btn-primary btn-lg w-100 rounded-3 shadow-sm">
              🔍search
            </button>
          </div>

        </div>

      </form>

    </div>
  </div>

  <!-- Back Button -->
  <div class="mt-4">
    <a href="/portal" class="btn btn-outline-secondary rounded-pill px-4">
      ⬅ Back
    </a>
  </div>

</div>