<% layout('layouts/boilerplate.ejs') %>

<div class="container my-5">

  <div class="text-center mb-4">
    <h1 class="fw-bold" style="color: #2c3e50;">Student Fee Dashboard</h1>
    <p class="text-muted">Detailed overview for Roll No: <%= student.rollNo %></p>
  </div>

  <div class="card shadow-sm mb-4 border-primary">
    <div class="card-header bg-primary text-white fw-bold d-flex justify-content-between align-items-center">
      <span><i class="bi bi-person-fill"></i> Personal Information</span>
      <% if (student.isHosteller) { %>
        <span class="badge bg-light text-primary px-3">HOSTEL ACTIVE</span>
      <% } %>
    </div>
    <div class="card-body">
      <div class="row">
        <div class="col-md-6 mb-2"><strong>Name:</strong> <%= student.name %></div>
        <div class="col-md-6 mb-2"><strong>Roll No:</strong> <%= student.rollNo %></div>
        <div class="col-md-6 mb-2"><strong>Course:</strong> <%= student.course %></div>
        <div class="col-md-6 mb-2"><strong>Branch:</strong> <%= student.branch.name %></div>
        <div class="col-md-6 mb-2"><strong>Year:</strong> <%= student.year %></div>
        <div class="col-md-6 mb-2"><strong>Contact:</strong> <%= student.contactNumber %></div>
        <div class="col-md-6 mb-2"><strong>Email:</strong> <%= student.email %></div>
        <div class="col-md-12 mb-2"><strong>Address:</strong> <%= student.address || "—" %></div>
        <div class="col-md-12 mb-2">
          <strong>Date of Admission:</strong>
          <%= new Date(student.dateOfAdmission).toLocaleDateString() %>
        </div>
        <div class="col-md-12 mt-2">
          <strong>Accommodation Type:</strong> 
          <% if (student.isHosteller) { %>
            <span class="badge bg-success px-3">ACTIVE (Hosteller)</span>
          <% } else { %>
            <span class="badge bg-secondary px-3">NOT OPTED (Day Scholar)</span>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <div class="card shadow-sm mb-4 border-success">
    <div class="card-header bg-success text-white fw-bold">
      <i class="bi bi-receipt"></i> Fee Structure Details
    </div>
    <div class="card-body">
      <% if (student.feeStructure) { %>
        <div class="d-flex justify-content-between align-items-center mb-3">
          <p class="mb-0"><strong>Academic Session:</strong> <%= student.feeStructure.academicYear %></p>
          <div class="text-end">
            <span class="text-muted small">Total consolidatedFee</span><br>
            <span class="badge bg-warning text-dark fs-5">
              ₹<%= expectedTotal.toLocaleString() %>
            </span>
          </div>
        </div>

        <p class="mb-1 fw-bold text-muted small">BREAKDOWN:</p>
        <ul class="list-group list-group-flush border rounded">
          <li class="list-group-item d-flex justify-content-between">
            <span>Tuition Fee:</span>
            <span>₹<%= student.feeStructure.breakdown.tuition.toFixed(2) %></span>
          </li>
          <li class="list-group-item d-flex justify-content-between">
            <span>Caution Money:</span>
            <% if (student.year == 1) { %>
              <span>₹<%= student.feeStructure.breakdown.cautionMoney.toFixed(2) %></span>
            <% } else { %>
              <span>N/A</span>
            <% } %>
          </li>
          <li class="list-group-item d-flex justify-content-between">
            <span>Examination Fee:</span>
            <span>₹<%= student.feeStructure.breakdown.exam.toFixed(2) %></span>
          </li>
          <li class="list-group-item d-flex justify-content-between">
            <span>Activity Charges:</span>
            <span>₹<%= student.feeStructure.breakdown.activity.toFixed(2) %></span>
          </li>
          
          <% if (student.isHosteller) { %>
            <li class="list-group-item d-flex justify-content-between bg-light border-start border-warning border-4">
              <span class="fw-bold text-primary">🏠 Hostel Accommodation Fee:</span>
              <span class="fw-bold text-primary">₹<%= student.feeStructure.hostelFee.toFixed(2) %></span>
            </li>
          <% } %>

          <li class="list-group-item d-flex justify-content-between">
            <span>Others / Miscellaneous:</span>
            <span>₹<%= student.feeStructure.breakdown.others.toFixed(2) %></span>
          </li>
        </ul>
      <% } else { %>
        <div class="alert alert-warning mb-0">No fee structure assigned to this record.</div>
      <% } %>
    </div>
  </div>

  <div class="card shadow-sm mb-4 border-info">
    <div class="card-header bg-info text-white fw-bold">
      <i class="bi bi-credit-card"></i> Transaction History
    </div>
    <div class="card-body">
      <div class="row text-center mb-4">
        <div class="col-md-6 mb-2">
          <div class="p-3 border rounded bg-light">
            <div class="text-muted small text-uppercase">Total Amount Paid</div>
            <div class="h4 fw-bold text-success">₹<%= totalPaid.toFixed(2) %></div>
          </div>
        </div>
        <div class="col-md-6 mb-2">
          <div class="p-3 border rounded bg-light">
            <div class="text-muted small text-uppercase">Outstanding Balance</div>
            <div class="h4 fw-bold text-danger">₹<%= remainingBalance.toFixed(2) %></div>
          </div>
        </div>
      </div>

      <% if (payments.length > 0) { %>
        <div class="table-responsive">
          <table class="table table-bordered table-hover align-middle shadow-sm">
            <thead class="table-dark text-center">
              <tr>
                <th>#</th>
                <th>Amount</th>
                <th>Mode</th>
                <th>Receipt No</th>
                <th>Date</th>
              </tr>
            </thead>
            <tbody class="text-center">
              <% payments.forEach((p, index) => { %>
                <tr>
                  <td><%= index + 1 %></td>
                  <td class="fw-bold text-success">₹<%= p.amountPaid.toFixed(2) %></td>
                  <td class="text-uppercase small fw-bold text-muted">
    <%= p.paymentMode %>
</td>
                  <td><code><%= p.receiptNumber %></code></td>
                  <td><%= new Date(p.paymentDate).toLocaleDateString() %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="text-center py-4 text-muted border rounded bg-light">
          <i class="bi bi-info-circle"></i> No payment history found for this student.
        </div>
      <% } %>

      <div class="mt-4 pt-3 border-top d-flex justify-content-between">
        <a href="/api/v1/students" class="btn btn-secondary px-4 shadow-sm">
          <i class="bi bi-arrow-left"></i> Back to Search
        </a>

        <% if (remainingBalance > 0) { %>
          <a href="/api/v1/payments/new?studentId=<%= student._id %>" class="btn btn-success px-4 shadow-sm fw-bold">
            💳 Proceed to Payment
          </a>
        <% } else { %>
          <button class="btn btn-outline-success px-4" disabled>✅ Fully Paid</button>
        <% } %>
      </div>
    </div>
  </div>
</div>