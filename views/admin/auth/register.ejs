<% layout("layouts/boilerplate") %>

<style>
  /* Page background and centering - Same as Login */
  .auth-wrapper {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    min-height: 90vh; 
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 20px;
  }

  /* Matching Card Styling */
  .auth-card {
    background: #ffffff;
    border-radius: 15px;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
    width: 100%;
    max-width: 400px;
    padding: 30px;
  }

  /* Consistent Input Styling */
  .form-label {
    font-weight: 600;
    color: #444;
    margin-bottom: 5px;
    display: block;
    font-size: 0.9rem;
  }

  .form-control {
    border-radius: 8px;
    border: 1px solid #ddd;
    padding: 10px;
    width: 100%;
    margin-bottom: 15px;
  }

  /* Consistent Success Gradient Button */
  .btn-success-gradient {
    background: linear-gradient(to right, #28a745, #218838);
    border: none;
    color: white;
    padding: 12px;
    border-radius: 8px;
    font-weight: bold;
    width: 100%;
    transition: 0.3s;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .btn-success-gradient:hover {
    opacity: 0.9;
    transform: translateY(-2px);
  }

  .login-link {
    color: #764ba2;
    text-decoration: none;
    font-weight: 600;
    transition: 0.2s;
  }

  .login-link:hover {
    text-decoration: underline;
  }
</style>

<div class="auth-wrapper">
  <div class="auth-card">
    <div class="text-center mb-4">
      <h2 class="fw-bold" style="color: #333;">Admin Register</h2>
      <p class="text-muted">Create an account to manage college fees</p>
    </div>

    <form method="POST" action="/api/v1/admin/register">
      <div>
        <label class="form-label">Username</label>
        <input type="text" name="username" class="form-control" placeholder="Choose a username" required>
      </div>

      <div>
        <label class="form-label">Email Address</label>
        <input type="email" name="email" class="form-control" placeholder="email@college.edu" required>
      </div>

      <div>
        <label class="form-label">Password</label>
        <input type="password" name="password" class="form-control" placeholder="Create a strong password" required>
      </div>

      <button type="submit" class="btn-success-gradient shadow-sm mt-2">
        REGISTER NOW
      </button>
    </form>

    <div class="mt-4 pt-3 border-top text-center">
      <p class="small text-muted mb-0">
        Already have an account? 
        <a href="/api/v1/admin/login" class="login-link">Login here</a>
      </p>
    </div>
  </div>
</div>