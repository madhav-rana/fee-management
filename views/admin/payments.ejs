<% layout("layouts/boilerplate") %>

<div class="container my-5">
  <h1 class="fw-bold text-center mb-4">Admin – Payments</h1>

  <div class="table-responsive shadow-sm rounded">
    <table class="table table-hover align-middle bg-white">
      <thead class="table-dark text-center">
        <tr>
          <th>#</th>
          <th>Student</th>
          <th>Roll No</th>
          <th>Branch</th>
          <th>Amount Paid</th>
          <th>Mode</th>
          <th>Date</th>
          <th>Receipt</th>
        </tr>
      </thead>

      <tbody>
        <% payments.forEach((p, index) => { %>
          <tr class="text-center">
            <td><%= index + 1 %></td>

            <td class="fw-bold"><%= p.student ? p.student.name : 'Unknown' %></td>
            <td><%= p.student ? p.student.rollNo : 'N/A' %></td>
            <td class="small text-muted"><%= (p.student && p.student.branch) ? p.student.branch.name : 'N/A' %></td>

            <td class="fw-bold text-primary">₹<%= p.amountPaid.toLocaleString('en-IN') %></td>

            <td>
              <span class="badge rounded-pill bg-info text-dark px-3 py-2">
                <%= p.paymentMode.toUpperCase() %>
              </span>
            </td>

            <td>
              <%= new Date(p.paymentDate).toLocaleDateString('en-IN') %>
            </td>

            <!-- <td>
              < if (p.receiptPdfUrl) { %>
                <a href="<= p.receiptPdfUrl %>" target="_blank" class="btn btn-sm btn-success px-3 shadow-sm">
                  <i class="bi bi-eye"></i> View
                </a>
              < } else { %>
                <a href="/api/v1/payments/receipt/<= p._id %>/pdf" class="btn btn-sm btn-warning px-3 shadow-sm text-dark">
                  <i class="bi bi-file-earmark-pdf"></i> Generate
                </a>
              < } %>
            </td> -->
            
            <td>
              <a href="/api/v1/payments/receipt/<%= p._id %>" 
                class="btn btn-sm btn-primary px-3 shadow-sm">
                <i class="bi bi-eye"></i> View
              </a>
              <a href="/api/v1/payments/receipt/<%= p._id %>/pdf" 
                class="btn btn-sm btn-success px-3 shadow-sm">
                <i class="bi bi-file-earmark-pdf"></i> PDF
              </a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="text-center mt-4">
    <a href="/api/v1/admin/dashboard" class="btn btn-secondary px-4 shadow-sm">
      ⬅ Back
    </a>
  </div>
</div>