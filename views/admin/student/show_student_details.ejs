<% layout('layouts/boilerplate.ejs') %>

<div class="container my-5">

  <div class="text-center mb-4">
    <h1 class="fw-bold" style="color: #2c3e50;">Student Details</h1>
    <p class="text-muted">View student info and fee status</p>
  </div>

  <div class="card shadow mb-4 border-primary">
    <div class="card-header bg-primary text-white fw-bold d-flex justify-content-between align-items-center">
      <span>Personal Information</span>
      <% if (student.isHosteller) { %>
          <span class="badge bg-light text-primary px-3">HOSTEL ACTIVE</span>
      <% } %>
    </div>
    <div class="card-body">
      <div class="row">
        <div class="col-md-6 mb-2"><strong>Name:</strong> <%= student.name %></div>
        <div class="col-md-6 mb-2"><strong>Roll No:</strong> <%= student.rollNo %></div>
        <div class="col-md-6 mb-2"><strong>Course:</strong> <%= student.course %></div>
        <div class="col-md-6 mb-2"><strong>Branch:</strong> <%= student.branch.name %></div>
        <div class="col-md-6 mb-2"><strong>Year:</strong> <%= student.year %></div>
        <div class="col-md-6 mb-2"><strong>Contact:</strong> <%= student.contactNumber %></div>
        <div class="col-md-6 mb-2"><strong>Email:</strong> <%= student.email %></div>
        <div class="col-md-12 mb-2"><strong>Address:</strong> <%= student.address || "—" %></div>
        <div class="col-md-12 mb-2">
          <strong>Date of Admission:</strong>
          <%= new Date(student.dateOfAdmission).toLocaleDateString() %>
        </div>
      </div>
      
      <hr>
      
      <div class="d-flex align-items-center justify-content-between">
        <div>
            <strong>Hostel Status:</strong> 
            <% if (student.isHosteller) { %>
                <span class="badge bg-success text-white px-3">ACTIVE (Hosteller)</span>
            <% } else { %>
                <span class="badge bg-secondary text-white px-3">NOT OPTED</span>
            <% } %>
        </div>
        <form action="/api/v1/admin/students/toggle-hostel/<%= student._id %>" method="POST">
            <button type="submit" class="btn btn-sm <%= student.isHosteller ? 'btn-outline-danger' : 'btn-outline-success' %> rounded-pill">
                <%= student.isHosteller ? '❌ Deactivate Hostel' : '🏠 Activate Hostel' %>
            </button>
        </form>
      </div>
    </div>
  </div>

  <div class="card shadow mb-4 border-success">
    <div class="card-header bg-success text-white fw-bold">
      Fee Structure Details
    </div>
    <div class="card-body">
      <% if (student.feeStructure) { %>
        <div class="row mb-3">
            <div class="col-md-6">
                <p><strong>Academic Year:</strong> <%= student.feeStructure.academicYear %></p>
            </div>
            <div class="col-md-6 text-md-end">
                <p><strong>Total Consolidated Bill:</strong> 
                   <span class="badge bg-warning text-dark fs-6">
                     ₹<%= expectedTotal.toLocaleString() %>
                   </span>
                </p>
            </div>
        </div>

        <p class="mb-1 fw-bold text-uppercase small text-muted">Fee Breakdown:</p>
        <ul class="list-group list-group-flush border rounded">
          <li class="list-group-item d-flex justify-content-between">
              <span>Tuition Fee</span>
              <span>₹<%= student.feeStructure.breakdown.tuition.toFixed(2) %></span>
          </li>
          <li class="list-group-item d-flex justify-content-between">
              <span>Caution Money</span>
              <% if (student.year == 1) { %>
                <span>₹<%= student.feeStructure.breakdown.cautionMoney.toFixed(2) %></span>
              <% } else { %>
                <span>N/A</span>
              <% } %>
          </li>
          <li class="list-group-item d-flex justify-content-between">
              <span>Examination Fee</span>
              <span>₹<%= student.feeStructure.breakdown.exam.toFixed(2) %></span>
          </li>
          <li class="list-group-item d-flex justify-content-between">
              <span>Activity Fee</span>
              <span>₹<%= student.feeStructure.breakdown.activity.toFixed(2) %></span>
          </li>
          
          <% if (student.isHosteller) { %>
            <li class="list-group-item d-flex justify-content-between bg-light border-start border-warning border-4">
                <span class="fw-bold text-warning-emphasis">🏠 Hostel Accommodation Fee</span>
                <span class="fw-bold">₹<%= student.feeStructure.hostelFee.toFixed(2) %></span>
            </li>
          <% } %>

          <li class="list-group-item d-flex justify-content-between">
              <span>Other Charges</span>
              <span>₹<%= student.feeStructure.breakdown.others.toFixed(2) %></span>
          </li>
        </ul>
      <% } else { %>
        <div class="alert alert-warning">No fee structure assigned to this student.</div>
      <% } %>
    </div>
  </div>

  <div class="card shadow mb-4 border-info">
    <div class="card-header bg-info text-white fw-bold">
      Payment History & Outstanding Dues
    </div>
    <div class="card-body">
      <div class="row text-center mb-4">
          <div class="col-md-6">
              <div class="p-3 border rounded bg-light">
                  <div class="text-muted small text-uppercase">Total Paid</div>
                  <div class="h4 fw-bold text-success">₹<%= totalPaid.toFixed(2) %></div>
              </div>
          </div>
          <div class="col-md-6">
              <div class="p-3 border rounded bg-light">
                  <div class="text-muted small text-uppercase">Remaining Balance</div>
                  <div class="h4 fw-bold text-danger">₹<%= remainingBalance.toFixed(2) %></div>
              </div>
          </div>
      </div>

      <% if (payments.length > 0) { %>
        <div class="table-responsive">
          <table class="table table-bordered table-hover align-middle">
            <thead class="table-dark">
              <tr>
                <th>#</th>
                <th>Amount Paid</th>
                <th>Mode</th>
                <th>Receipt No</th>
                <th>Date</th>
              </tr>
            </thead>
            <tbody>
              <% payments.forEach((p, index) => { %>
                <tr>
                  <td><%= index + 1 %></td>
                  <td class="fw-bold text-success">₹<%= p.amountPaid.toFixed(2) %></td>
                    <td class="text-uppercase small fw-bold text-muted">
    <%= p.paymentMode %>
</td>
                  <td><code><%= p.receiptNumber %></code></td>
                  <td><%= new Date(p.paymentDate).toLocaleDateString() %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="text-center py-4">
            <p class="text-muted mb-0">No transactions found for this student.</p>
        </div>
      <% } %>

      <div class="mt-4 pt-3 border-top d-flex justify-content-between">
          <a href="/api/v1/admin/students" class="btn btn-secondary px-4">
            ⬅ Back to Search
          </a>
          
          <% if (remainingBalance > 0) { %>
            <a href="/api/v1/payments/new?studentId=<%= student._id %>" class="btn btn-success px-4 shadow-sm">
              💳 Continue Payment
            </a>
          <% } else { %>
            <button class="btn btn-success px-4" disabled>✅ Fully Paid</button>
          <% } %>
      </div>
    </div>
  </div>

</div>