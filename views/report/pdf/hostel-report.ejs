<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <style>
    body {
      font-family: 'Segoe UI', sans-serif;
      font-size: 13px;
      color: #2c3e50;
      padding: 30px;
    }

    .header {
      text-align: center;
      margin-bottom: 25px;
      border-bottom: 2px solid #2c3e50;
      padding-bottom: 15px;
    }

    .header h2 {
      margin: 0;
      font-size: 20px;
      font-weight: bold;
    }

    .header p {
      margin: 5px 0 0;
      font-size: 13px;
      color: #666;
    }

    .meta {
      display: flex;
      justify-content: space-between;
      margin-bottom: 20px;
      font-size: 12px;
      color: #555;
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    thead {
      background-color: #2c3e50;
      color: white;
    }

    th, td {
      padding: 9px 12px;
      text-align: left;
      border: 1px solid #ddd;
    }

    tbody tr:nth-child(even) {
      background-color: #f5f6fa;
    }

    .footer {
      margin-top: 30px;
      text-align: center;
      font-size: 11px;
      color: #999;
      border-top: 1px solid #ddd;
      padding-top: 10px;
    }
  </style>
</head>
<body>

  <div class="header">
    <h2>
      <%= type === "hosteler" ? "🏠 Hostelers Report" : type === "dayscholar" ? "🚌 Day Scholars Report" : "Hosteler / Day Scholar Report" %>
    </h2>
    <p>
      <%= branch ? `Branch: ${branch.toUpperCase()}` : "All Branches" %> |
      <%= year ? `Year: ${year}` : "All Years" %> |
      Generated on: <%= new Date().toLocaleDateString("en-IN", { day: "2-digit", month: "long", year: "numeric" }) %>
    </p>
  </div>

  <div class="meta">
    <span>Total Students: <strong><%= report.length %></strong></span>
  </div>

  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Name</th>
        <th>Roll No</th>
        <th>Branch</th>
        <th>Year</th>
        <th>Contact</th>
      </tr>
    </thead>
    <tbody>
      <% report.forEach((s, i) => { %>
        <tr>
          <td><%= i + 1 %></td>
          <td><%= s.name %></td>
          <td><%= s.rollNo %></td>
          <td><%= s.branchName %> (<%= s.branchCode %>)</td>
          <td>Year <%= s.year %></td>
          <td><%= s.contactNumber %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <div class="footer">
    This is a system generated report. &copy; Fee Management System
  </div>

</body>
</html>