<% layout("layouts/boilerplate") %>

<div class="container my-5">

  <!-- HEADER -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h3 class="fw-bold m-0">
        <i class="bi bi-house-fill text-primary me-2"></i>Hosteler / Day Scholar Report
      </h3>
      <p class="text-muted small m-0">View students by accommodation type</p>
    </div>
  </div>

  <!-- FILTERS -->
  <div class="bg-light p-3 rounded-3 mb-4 shadow-sm">
    <form method="GET" action="/api/v1/reports/hostel" class="row g-3">

      <div class="col-md-4">
        <label class="form-label small fw-bold">BRANCH</label>
        <select name="branch" class="form-select">
          <option value="">All Branches</option>
          <% branches.forEach(b => { %>
            <option value="<%= b.code %>" <%= branch === b.code ? "selected" : "" %>>
              <%= b.name %> (<%= b.code %>)
            </option>
          <% }) %>
        </select>
      </div>

      <div class="col-md-3">
        <label class="form-label small fw-bold">YEAR</label>
        <select name="year" class="form-select">
          <option value="">All Years</option>
          <option value="1" <%= year === "1" ? "selected" : "" %>>Year 1</option>
          <option value="2" <%= year === "2" ? "selected" : "" %>>Year 2</option>
          <option value="3" <%= year === "3" ? "selected" : "" %>>Year 3</option>
          <option value="4" <%= year === "4" ? "selected" : "" %>>Year 4</option>
        </select>
      </div>

      <div class="col-md-5 d-flex align-items-end">
        <button class="btn btn-primary w-100 rounded-pill fw-bold">
          <i class="bi bi-search me-1"></i> Generate Report
        </button>
      </div>

    </form>
  </div>

  <!-- TYPE TOGGLE -->
  <% if (report.length > 0 || type) { %>
    <div class="d-flex gap-2 mb-4">
      <a href="?branch=<%= branch %>&year=<%= year %>"
         class="btn <%= !type ? 'btn-primary' : 'btn-outline-primary' %> rounded-pill">
        All
      </a>
      <a href="?branch=<%= branch %>&year=<%= year %>&type=hosteler"
         class="btn <%= type === 'hosteler' ? 'btn-success' : 'btn-outline-success' %> rounded-pill">
        🏠 Hostelers
      </a>
      <a href="?branch=<%= branch %>&year=<%= year %>&type=dayscholar"
         class="btn <%= type === 'dayscholar' ? 'btn-warning' : 'btn-outline-warning' %> rounded-pill">
        🚌 Day Scholars
      </a>
    </div>
  <% } %>

  <!-- SUMMARY BADGES -->
  <% if (report.length > 0) { %>
    <div class="d-flex gap-3 mb-3">
      <span class="badge bg-success fs-6 px-3 py-2 rounded-pill">
        🏠 Hostelers: <%= report.filter(s => s.isHosteller).length %>
      </span>
      <span class="badge bg-warning text-dark fs-6 px-3 py-2 rounded-pill">
        🚌 Day Scholars: <%= report.filter(s => !s.isHosteller).length %>
      </span>
      <span class="badge bg-secondary fs-6 px-3 py-2 rounded-pill">
        Total: <%= report.length %>
      </span>
    </div>
  <% } %>

  <!-- TABLE -->
  <% if (report.length === 0) { %>
    <div class="text-center py-5">
      <i class="bi bi-search fs-1 text-muted"></i>
      <h5 class="mt-3 text-muted">No data found. Apply filters and generate report.</h5>
    </div>
  <% } else { %>
    <div class="table-responsive shadow-sm rounded-4">
      <table class="table align-middle mb-0">
        <thead class="table-dark">
          <tr>
            <th class="ps-3">#</th>
            <th>Name</th>
            <th>Roll No</th>
            <th>Branch</th>
            <th class="text-center">Year</th>
            <th>Contact</th>
            <th class="text-center">Type</th>
          </tr>
        </thead>
        <tbody>
          <% report.forEach((s, i) => { %>
            <tr>
              <td class="ps-3 text-muted"><%= i + 1 %></td>
              <td class="fw-bold"><%= s.name %></td>
              <td class="text-secondary"><%= s.rollNo %></td>
              <td><%= s.branchName %> (<%= s.branchCode %>)</td>
              <td class="text-center">
                <span class="badge bg-secondary">Year <%= s.year %></span>
              </td>
              <td><%= s.contactNumber %></td>
              <td class="text-center">
                <% if (s.isHosteller) { %>
                  <span class="badge bg-success">🏠 Hosteler</span>
                <% } else { %>
                  <span class="badge bg-warning text-dark">🚌 Day Scholar</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>

</div>