<% layout("layouts/boilerplate") %>

<div class="container my-5">

  <!-- HEADER -->
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
      <h3 class="fw-bold m-0">
        <i class="bi bi-bar-chart-line-fill text-primary me-2"></i>
        Fee Status Report
      </h3>
      <p class="text-muted small m-0">View paid and unpaid students</p>
    </div>

    <% if (report.length > 0) { %>
      <a href="?branch=<%= branch || '' %>&filter=<%= filter || '' %>&export=pdf"
         class="btn btn-danger rounded-pill">
        <i class="bi bi-file-earmark-pdf"></i> Export PDF
      </a>
    <% } %>
  </div>

  <!-- FILTERS -->
  <div class="bg-light p-3 rounded-3 mb-4 shadow-sm">
    <form method="GET" action="/api/v1/reports/student-status" class="row g-3">

      <div class="col-md-4">
        <label class="form-label small fw-bold">BRANCH</label>
        <select name="branch" class="form-select">
          <option value="">All</option>
          <% branches.forEach(b => { %>
            <option value="<%= b.code %>" <%= branch === b.code ? "selected" : "" %>>
              <%= b.name %>
            </option>
          <% }) %>
        </select>
      </div>

      <!-- TAB FILTER -->
      <div class="col-md-8 d-flex align-items-end gap-2">
        <a href="?branch=<%= branch || '' %>" 
           class="btn <%= !filter ? 'btn-primary' : 'btn-outline-primary' %> rounded-pill">
          All
        </a>

        <a href="?branch=<%= branch || '' %>&filter=paid" 
           class="btn <%= filter === 'paid' ? 'btn-success' : 'btn-outline-success' %> rounded-pill">
          Paid
        </a>

        <a href="?branch=<%= branch || '' %>&filter=unpaid" 
           class="btn <%= filter === 'unpaid' ? 'btn-danger' : 'btn-outline-danger' %> rounded-pill">
          Unpaid
        </a>
      </div>

    </form>
  </div>

  <!-- TABLE -->
  <% if (report.length === 0) { %>
    <div class="text-center py-5">
      <i class="bi bi-check-circle-fill text-success fs-1"></i>
      <h5 class="mt-3">No data found</h5>
    </div>
  <% } else { %>

    <div class="table-responsive shadow-sm rounded-4">
      <table class="table align-middle mb-0">
        <thead class="table-dark">
          <tr>
            <th>#</th>
            <th>Name</th>
            <th>Roll No</th>
            <th>Branch</th>
            <th class="text-center">Status</th>
          </tr>
        </thead>

        <tbody>
          <% report.forEach((s, i) => { %>
            <tr>
              <td><%= i + 1 %></td>
              <td class="fw-bold"><%= s.name %></td>
              <td><%= s.rollNo %></td>
              <td><%= s.branchName %> (<%= s.branchCode %>)</td>
              <td class="text-center">
                <% if (s.status === "PAID") { %>
                  <span class="badge bg-success">PAID</span>
                <% } else { %>
                  <span class="badge bg-danger">UNPAID</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

  <% } %>

</div>