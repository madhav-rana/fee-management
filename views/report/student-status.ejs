<% layout("layouts/boilerplate") %>

<div class="container my-5">

  <!-- HEADER -->
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
      <h3 class="fw-bold m-0">
        <i class="bi bi-bar-chart-line-fill text-primary me-2"></i>Fee Status Report
      </h3>
      <p class="text-muted small m-0">View paid and unpaid students</p>
    </div>
    <% if (report.length > 0) { %>
      <a href="?branch=<%= branch %>&year=<%= year %>&academicYear=<%= academicYear %>&filter=<%= filter %>&export=pdf"
         class="btn btn-danger rounded-pill">
        <i class="bi bi-file-earmark-pdf"></i> Export PDF
      </a>
    <% } %>
  </div>

  <!-- FILTERS -->
  <div class="bg-light p-3 rounded-3 mb-4 shadow-sm">
    <form method="GET" action="/api/v1/reports/student-status" class="row g-3">

      <div class="col-md-3">
        <label class="form-label small fw-bold">ACADEMIC YEAR</label>
        <select name="academicYear" class="form-select">
          <option value="">All</option>
          <% allFeeStructures.forEach(f => { %>
            <option value="<%= f.academicYear %>" <%= academicYear === f.academicYear ? "selected" : "" %>>
              <%= f.academicYear %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="col-md-3">
        <label class="form-label small fw-bold">BRANCH</label>
        <select name="branch" class="form-select">
          <option value="">All Branches</option>
          <% branches.forEach(b => { %>
            <option value="<%= b.code %>" <%= branch === b.code ? "selected" : "" %>>
              <%= b.name %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="col-md-2">
        <label class="form-label small fw-bold">YEAR</label>
        <select name="year" class="form-select">
          <option value="">All Years</option>
          <option value="1" <%= year === "1" ? "selected" : "" %>>Year 1</option>
          <option value="2" <%= year === "2" ? "selected" : "" %>>Year 2</option>
          <option value="3" <%= year === "3" ? "selected" : "" %>>Year 3</option>
          <option value="4" <%= year === "4" ? "selected" : "" %>>Year 4</option>
        </select>
      </div>

      <div class="col-md-4 d-flex align-items-end">
        <button class="btn btn-primary w-100 rounded-pill fw-bold">
          <i class="bi bi-search me-1"></i> Generate Report
        </button>
      </div>

    </form>
  </div>

  <!-- PAID / UNPAID TOGGLE -->
  <% if (report.length > 0 || filter) { %>
    <div class="d-flex gap-2 mb-4">
      <a href="?branch=<%= branch %>&year=<%= year %>&academicYear=<%= academicYear %>"
         class="btn <%= !filter ? 'btn-primary' : 'btn-outline-primary' %> rounded-pill">
        All
      </a>
      <a href="?branch=<%= branch %>&year=<%= year %>&academicYear=<%= academicYear %>&filter=paid"
         class="btn <%= filter === 'paid' ? 'btn-success' : 'btn-outline-success' %> rounded-pill">
        Paid
      </a>
      <a href="?branch=<%= branch %>&year=<%= year %>&academicYear=<%= academicYear %>&filter=unpaid"
         class="btn <%= filter === 'unpaid' ? 'btn-danger' : 'btn-outline-danger' %> rounded-pill">
        Unpaid
      </a>
    </div>
  <% } %>

  <!-- TABLE -->
  <% if (report.length === 0) { %>
    <div class="text-center py-5">
      <i class="bi bi-search fs-1 text-muted"></i>
      <h5 class="mt-3 text-muted">No data found. Apply filters and generate report.</h5>
    </div>
  <% } else { %>
    <div class="table-responsive shadow-sm rounded-4">
      <table class="table align-middle mb-0">
        <thead class="table-dark">
          <tr>
            <th>#</th>
            <th>Name</th>
            <th>Roll No</th>
            <th>Branch</th>
            <th class="text-center">Year</th>
            <th class="text-center">Status</th>
          </tr>
        </thead>
        <tbody>
          <% report.forEach((s, i) => { %>
            <tr>
              <!-- <td><%= i + 1 %></td> -->
              <td><%= (currentPage - 1) * 20 + i + 1 %></td>
              <td class="fw-bold"><%= s.name %></td>
              <td><%= s.rollNo %></td>
              <td><%= s.branchName %> (<%= s.branchCode %>)</td>
              <td class="text-center">
                <span class="badge bg-secondary">Year <%= s.year %></span>
              </td>
              <td class="text-center">
                <% if (s.status === "PAID") { %>
                  <span class="badge bg-success">PAID</span>
                <% } else { %>
                  <span class="badge bg-danger">UNPAID</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
      <!-- PAGINATION -->
      <% if (totalPages > 1) { %>
        <div class="d-flex justify-content-between align-items-center mt-4">

          <p class="text-muted small m-0">
            Showing <%= (currentPage - 1) * 20 + 1 %> - <%= Math.min(currentPage * 20, totalCount) %> of <%= totalCount %> students
          </p>

          <nav>
            <ul class="pagination mb-0">

              <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                <a class="page-link rounded-start-pill"
                  href="?branch=<%= branch %>&year=<%= year %>&academicYear=<%= academicYear %>&filter=<%= filter %>&page=<%= currentPage - 1 %>">
                  &laquo;
                </a>
              </li>

              <% for(let i = 1; i <= totalPages; i++) { %>
                <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                  <a class="page-link"
                    href="?branch=<%= branch %>&year=<%= year %>&academicYear=<%= academicYear %>&filter=<%= filter %>&page=<%= i %>">
                    <%= i %>
                  </a>
                </li>
              <% } %>

              <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                <a class="page-link rounded-end-pill"
                  href="?branch=<%= branch %>&year=<%= year %>&academicYear=<%= academicYear %>&filter=<%= filter %>&page=<%= currentPage + 1 %>">
                  &raquo;
                </a>
              </li>

            </ul>
          </nav>

        </div>
      <% } %>
    </div>
  <% } %>

</div>