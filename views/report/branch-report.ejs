<% layout("layouts/boilerplate") %>

<div class="container my-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold m-0">
      <i class="bi bi-diagram-3-fill me-2 text-primary"></i>Branch-wise Fee Report (<%= academicYear %>)
    </h3>
    <a href="/api/v1/reports/branch?academicYear=<%= academicYear %>&export=pdf" class="btn btn-danger btn-sm rounded-pill px-3 shadow-sm">
      <i class="bi bi-file-earmark-pdf"></i> Export PDF
    </a>
  </div>

  <% if (report.length === 0) { %>
    <div class="alert alert-warning border-0 shadow-sm rounded-4">No data available</div>
  <% } else { %>
    <div class="table-responsive shadow-sm rounded-4">
      <table class="table table-hover align-middle bg-white mb-0">
        <thead class="table-dark">
          <tr>
            <th class="ps-4">Branch</th>
            <th class="text-center">No. Of Students</th>
            <th>Expected (₹)</th>
            <th>Collected (₹)</th>
            <th>Pending (₹)</th>
            <th class="text-center pe-4">Show Students</th> </tr>
        </thead>
        <tbody>
          <% report.forEach(r => { %>
            <tr>
              <td class="ps-4 fw-bold text-dark"><%= r.branchName %> (<%= r.branchCode %>)</td>
              <td class="text-center"><span class="badge bg-light text-dark border"><%= r.totalStudents %></span></td>
              <td>₹<%= r.expectedAmount.toLocaleString() %></td>
              <td class="text-success fw-bold">₹<%= r.totalCollected.toLocaleString() %></td>
              <td class="text-danger fw-bold">₹<%= r.pendingAmount.toLocaleString() %></td>
              <td class="text-center pe-4">
                <a href="/api/v1/reports/student-status?branch=<%= r.branchCode %>" class="btn btn-primary btn-sm rounded-pill px-3 shadow-sm">
                  <i class="bi bi-people-fill me-1"></i> Show Students
                </a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>