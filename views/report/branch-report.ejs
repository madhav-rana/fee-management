<% layout("layouts/boilerplate") %>

<div class="container my-5">

  <!-- HEADER -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold m-0">
      <i class="bi bi-diagram-3-fill me-2 text-primary"></i>Branch-wise Fee Report
    </h3>
    <a href="?academicYear=<%= academicYear %>&branch=<%= selectedBranch %>&year=<%= selectedYear %>&export=pdf"
       class="btn btn-danger btn-sm rounded-pill px-3 shadow-sm">
      <i class="bi bi-file-earmark-pdf"></i> Export PDF
    </a>
  </div>

  <!-- FILTERS -->
  <div class="bg-light p-3 rounded-3 mb-4 shadow-sm">
    <form method="GET" action="/api/v1/reports/branch" class="row g-3">

      <div class="col-md-3">
        <label class="form-label small fw-bold">ACADEMIC YEAR</label>
        <select name="academicYear" class="form-select">
          <% allFeeStructures.forEach(f => { %>
            <option value="<%= f.academicYear %>" <%= academicYear === f.academicYear ? "selected" : "" %>>
              <%= f.academicYear %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="col-md-3">
        <label class="form-label small fw-bold">BRANCH</label>
        <select name="branch" class="form-select">
          <option value="">All Branches</option>
          <% branches.forEach(b => { %>
            <option value="<%= b.code %>" <%= selectedBranch === b.code ? "selected" : "" %>>
              <%= b.name %> (<%= b.code %>)
            </option>
          <% }) %>
        </select>
      </div>

      <div class="col-md-3">
        <label class="form-label small fw-bold">YEAR</label>
        <select name="year" class="form-select">
          <option value="">All Years</option>
          <option value="1" <%= selectedYear === "1" ? "selected" : "" %>>Year 1</option>
          <option value="2" <%= selectedYear === "2" ? "selected" : "" %>>Year 2</option>
          <option value="3" <%= selectedYear === "3" ? "selected" : "" %>>Year 3</option>
          <option value="4" <%= selectedYear === "4" ? "selected" : "" %>>Year 4</option>
        </select>
      </div>

      <div class="col-md-3 d-flex align-items-end">
        <button class="btn btn-primary w-100 rounded-pill fw-bold">
          <i class="bi bi-file-earmark-text me-1"></i> Generate Report
        </button>
      </div>

    </form>
  </div>

  <!-- TABLE -->
  <% if (report.length === 0) { %>
    <div class="alert alert-warning border-0 shadow-sm rounded-4">No data available</div>
  <% } else { %>
    <div class="table-responsive shadow-sm rounded-4">
      <table class="table table-hover align-middle bg-white mb-0">
        <thead class="table-dark">
          <tr>
            <th class="ps-4">Branch</th>
            <th class="text-center">Year</th>
            <th class="text-center">Students</th>
            <th>Expected (₹)</th>
            <th>Collected (₹)</th>
            <th>Pending (₹)</th>
            <th class="text-center pe-4">Show Students</th>
          </tr>
        </thead>
        <tbody>
          <% report.forEach(r => { %>
            <tr>
              <td class="ps-4 fw-bold text-dark"><%= r.branchName %> (<%= r.branchCode %>)</td>
              <td class="text-center">
                <span class="badge bg-secondary">Year <%= r.year %></span>
              </td>
              <td class="text-center">
                <span class="badge bg-light text-dark border"><%= r.totalStudents %></span>
              </td>
              <td>₹<%= r.expectedAmount.toLocaleString() %></td>
              <td class="text-success fw-bold">₹<%= r.totalCollected.toLocaleString() %></td>
              <td class="text-danger fw-bold">₹<%= r.pendingAmount.toLocaleString() %></td>
              <td class="text-center pe-4">
                <!-- <a href="/api/v1/reports/student-status?branch=<%= r.branchCode %>&year=<%= r.year %>"
                   class="btn btn-primary btn-sm rounded-pill px-3 shadow-sm">
                  <i class="bi bi-people-fill me-1"></i> Show Students
                </a> -->
                <a href="/api/v1/reports/student-status?branch=<%= r.branchCode %>&year=<%= r.year %>&academicYear=<%= academicYear %>"
                   class="btn btn-primary btn-sm rounded-pill px-3 shadow-sm">
                  <i class="bi bi-people-fill me-1"></i> Show Students
                </a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>

</div>